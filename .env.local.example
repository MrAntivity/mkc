# Copy this file to .env.local and fill in once you've created a Shopify
# custom app with Storefront API access (Admin > Settings > Apps and sales
# channels > Develop apps).

NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=shpat_your_public_storefront_token
NEXT_PUBLIC_SHOPIFY_STOREFRONT_API_VERSION=2025-01
